{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Playwright Test",
            "skipFiles": ["<node_internals>/**"],
            
            // זה הנתיב לקובץ שאתה רוצה להריץ כרגע
            "program": "${file}",

            // --- שורת המחץ: כאן אנחנו מגלים לו איפה Node נמצא ---
            "runtimeExecutable": "C:\\Program Files\\nodejs\\node.exe",
            
            // טוען את המשתנים (סיסמאות) מהקובץ .env
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}